{
  "name": "rate-repository-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!(.pnpm|react-native|@react-native|@react-native-community|expo|@expo|@expo-google-fonts|react-navigation|@react-navigation|@sentry/react-native|native-base|@apollo/client|react-router|react-router-native|formik|yup))"
    ],
    "moduleNameMapper": {
      "^expo-constants$": "<rootDir>/src/__mocks__/expo-constants.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/async-storage.js",
      "^.*/expo/src/winter/ImportMetaRegistry$": "<rootDir>/src/__mocks__/expo-winter.js"
    }
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-picker/picker": "^2.11.4",
    "date-fns": "^4.1.0",
    "expo": "~55.0.8",
    "expo-linking": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "formik": "^2.4.9",
    "graphql": "^16.13.1",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-router-native": "^6.30.3",
    "rxjs": "^7.8.2",
    "use-debounce": "^10.1.0",
    "yup": "^1.7.1"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.11",
    "react-test-renderer": "^19.2.0"
  }
}
